{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LinuxMacro",
  "version": "0.1.0",
  "identifier": "dev.linuxmacro.app",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "LinuxMacro Editor",
        "width": 1600,
        "height": 980,
        "minWidth": 1360,
        "minHeight": 840,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": ["icons/icon.png"]
  }
}
